{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/ZgrzytDesktop/ZgrzytDesktop.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/ZgrzytDesktop.sln",
        "--no-build"
      ],
      "dependsOn": "build",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish-release-win-x64",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/ZgrzytDesktop/ZgrzytDesktop.csproj",
        "-c",
        "Release",
        "-r",
        "win-x64",
        "--self-contained",
        "false"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    }
  ]
}
