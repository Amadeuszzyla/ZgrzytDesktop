<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:parts="clr-namespace:ZgrzytDesktop.Views.DashboardParts"
    x:CompileBindings="False">

    <Grid>
        <Grid ColumnDefinitions="240,*" Background="{DynamicResource AppPageBackgroundBrush}">

            <parts:DashboardSidebarView Grid.Column="0" />

            <Grid Grid.Column="1" RowDefinitions="Auto,*">

                <Border
                    Grid.Row="0"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppCardBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="22,16">

                    <StackPanel Spacing="3">
                        <TextBlock
                            Text="{Binding CurrentSectionTitle}"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="{DynamicResource AppPrimaryTextBrush}" />

                        <TextBlock
                            Text="{Binding LblHeaderSubtitle}"
                            Foreground="{DynamicResource AppMutedTextBrush}"
                            FontSize="13" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <parts:TicketsPanelView IsVisible="{Binding IsTicketsPageVisible}" />
                    <parts:TicketDetailsPanelView IsVisible="{Binding IsDetailsPageVisible}" />
                    <parts:StatisticsPanelView IsVisible="{Binding IsStatisticsPageVisible}" />
                    <parts:RequestAccountPanelView IsVisible="{Binding IsRequestAccountPageVisible}" />
                    <parts:AdminPanelView IsVisible="{Binding IsAdminPageVisible}" />
                    <parts:SettingsPanelView IsVisible="{Binding IsSettingsPageVisible}" />
                </Grid>

            </Grid>
        </Grid>

        <Border
            IsVisible="{Binding IsToastVisible}"
            Background="{Binding ToastBackground}"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,20,28,0"
            Padding="16,12"
            CornerRadius="10"
            MaxWidth="420"
            BorderBrush="#00000020"
            BorderThickness="1">

            <TextBlock
                Text="{Binding ToastMessage}"
                Foreground="{Binding ToastForeground}"
                FontSize="14"
                TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
