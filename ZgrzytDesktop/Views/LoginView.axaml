<UserControl
    x:Class="ZgrzytDesktop.Views.LoginView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <Grid Background="#111827">

        <Border
            Width="440"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#1F2937"
            BorderBrush="#374151"
            BorderThickness="1"
            CornerRadius="18"
            Padding="32">

            <StackPanel Spacing="15">

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="ZGRZYT Desktop"
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="White"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        Text="System zgłoszeń technicznych"
                        FontSize="14"
                        Foreground="#9CA3AF"
                        TextAlignment="Center"
                        HorizontalAlignment="Center" />
                </StackPanel>

                <Separator
                    Margin="0,8,0,4"
                    Background="#374151" />

                <TextBlock
                    Text="Logowanie"
                    FontSize="21"
                    FontWeight="Bold"
                    Foreground="White" />

                <TextBlock
                    Text="Login"
                    FontWeight="SemiBold"
                    Foreground="#D1D5DB" />

                <TextBox
                    Text="{Binding Login, Mode=TwoWay}"
                    PlaceholderText="Wpisz login"
                    Height="42"
                    FontSize="14"
                    Padding="10,9,10,5"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding IsNotLoading}" />

                <TextBlock
                    Text="Hasło"
                    FontWeight="SemiBold"
                    Foreground="#D1D5DB" />

                <TextBox
                    Text="{Binding Password, Mode=TwoWay}"
                    PasswordChar="•"
                    PlaceholderText="Wpisz hasło"
                    Height="42"
                    FontSize="14"
                    Padding="10,9,10,5"
                    VerticalContentAlignment="Center"
                    IsEnabled="{Binding IsNotLoading}" />

                <Button
                    Content="{Binding LoginButtonText}"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="12"
                    Margin="0,8,0,0"
                    FontWeight="SemiBold"
                    IsEnabled="{Binding IsNotLoading}" />

                <Border
                    Background="#7F1D1D"
                    CornerRadius="8"
                    Padding="10"
                    IsVisible="{Binding HasError}">

                    <TextBlock
                        Text="{Binding ErrorMessage}"
                        Foreground="#FEE2E2"
                        TextWrapping="Wrap" />
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>