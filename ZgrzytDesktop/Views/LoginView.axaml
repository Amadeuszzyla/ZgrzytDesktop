<UserControl
    x:Class="ZgrzytDesktop.Views.LoginView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ZgrzytDesktop.ViewModels"
    x:DataType="vm:LoginViewModel">

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource AppPageBackgroundBrush}">

        <Border Grid.Row="0" Classes="app-topbar">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <Image
                        Classes="topbar-logo"
                        Source="/Assets/zgrzyt-logo.png"
                        Width="36"
                        Height="36" />
                    <TextBlock Classes="topbar-brand" Text="ZGRZYT" />
                </StackPanel>

                <Border
                    Grid.Column="2"
                    Classes="version-badge"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
                    <TextBlock Classes="version-badge-text" Text="{Binding AppVersionDisplay}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border
                Classes="login-card"
                Width="440"
                MaxWidth="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="24">

                <StackPanel Spacing="18">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock
                            Classes="login-welcome-title"
                            Text="{Binding LblLoginTitle}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center" />

                        <TextBlock
                            Classes="login-welcome-subtitle"
                            Text="{Binding LblAppSubtitle}"
                            HorizontalAlignment="Center"
                            TextAlignment="Center" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            Classes="login-field-label"
                            Text="{Binding LblLoginLabel}" />

                        <TextBox
                            Classes="login-field"
                            Text="{Binding Login, Mode=TwoWay}"
                            PlaceholderText="{Binding LblLoginPlaceholder}"
                            MinHeight="44"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            IsEnabled="{Binding IsNotLoading}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            Classes="login-field-label"
                            Text="{Binding LblPasswordLabel}" />

                        <TextBox
                            Classes="login-field"
                            Text="{Binding Password, Mode=TwoWay}"
                            PasswordChar="•"
                            PlaceholderText="{Binding LblPasswordPlaceholder}"
                            MinHeight="44"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            IsEnabled="{Binding IsNotLoading}" />
                    </StackPanel>

                    <Button
                        Classes="btn-primary login-submit"
                        Content="{Binding LoginButtonText}"
                        Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsEnabled="{Binding IsNotLoading}" />

                    <Border
                        Classes="login-error"
                        IsVisible="{Binding HasError}">
                        <TextBlock
                            Classes="login-error-text"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
