<Window
    x:Class="ZgrzytDesktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ZgrzytDesktop.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/zgrzyt-logo.ico"
    Title="ZGRZYT Desktop"
    x:Name="RootWindow"
    Width="1200"
    Height="750"
    MinWidth="1000"
    MinHeight="650"
    WindowStartupLocation="CenterScreen">

    <ContentControl Content="{Binding CurrentViewModel}" />

</Window>