<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.TicketDetailsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">
<Grid
                ColumnDefinitions="1.2*,*"
                ColumnSpacing="20"
                Margin="{DynamicResource AppPagePadding}">

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" MinWidth="560">

                        <Border Classes="app-card">
                            <StackPanel Spacing="14">
                                <TextBlock Classes="section-title-large" Text="Informacje o zg┼éoszeniu" />

                                <Border Classes="app-subtle-panel">
                                    <TextBlock Text="{Binding DetailsStatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                </Border>

                                <TextBlock Text="Przetwarzanie..." IsVisible="{Binding IsLoadingDetails}" FontStyle="Italic" Foreground="{DynamicResource AppMutedTextBrush}" />

                                <TextBlock Classes="ticket-title" Text="{Binding TicketDetails.Title}" />

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Classes="app-chip">
                                        <TextBlock Classes="app-chip-text" Text="{Binding TicketDetails.DisplayStatus}" />
                                    </Border>
                                    <Border Classes="app-chip-warning">
                                        <TextBlock Classes="app-chip-text-warning" Text="{Binding TicketDetails.Priority}" />
                                    </Border>
                                </StackPanel>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="field-label" Text="Zg┼éaszaj─ůcy" Margin="0" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TicketDetails.User.Name}" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="field-label" Text="Przypisany IT" Margin="0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TicketDetails.AssignedTo.Name}" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </Grid>

                                <StackPanel Spacing="6">
                                    <TextBlock Classes="field-label" Text="Opis" Margin="0" />
                                    <Border Classes="app-subtle-panel">
                                        <TextBlock Text="{Binding TicketDetails.Description}" TextWrapping="Wrap" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource AppInfoPanelBackgroundBrush}" CornerRadius="10" Padding="12" IsVisible="{Binding IsRegularUser}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Mo┼╝esz zamkn─ů─ç w┼éasne zg┼éoszenie, je┼Ťli backend na to pozwala. Przy b┼é─Ödzie 403 operacja jest zablokowana po stronie API." TextWrapping="Wrap" Foreground="{DynamicResource AppInfoPanelForegroundBrush}" FontSize="12" IsVisible="{Binding CanCloseOwnTicket}" />
                                <TextBlock Text="Masz dost─Öp do podgl─ůdu zg┼éoszenia i wiadomo┼Ťci. Edycja statusu, priorytetu oraz przypisywanie s─ů dost─Öpne dla r├│l admin/it." TextWrapping="Wrap" Foreground="{DynamicResource AppInfoPanelForegroundBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource AppWarnPanelBackgroundBrush}" CornerRadius="10" Padding="12" IsVisible="{Binding IsOffline}">
                            <TextBlock Text="Tryb offline ÔÇö edycja, przypisywanie i wiadomo┼Ťci s─ů niedost─Öpne." TextWrapping="Wrap" Foreground="{DynamicResource AppWarnPanelForegroundBrush}" />
                        </Border>

                        <Border Classes="app-card" IsVisible="{Binding CanManageTickets}">
                            <StackPanel Spacing="14">
                                <TextBlock Classes="section-title-large" Text="Zarz─ůdzanie zg┼éoszeniem" />

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Classes="field-label" Text="Status" Margin="0" />
                                        <ComboBox MinHeight="38" ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding SelectedStatus}" IsEnabled="{Binding CanEditTicket}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock Classes="field-label" Text="Priorytet" Margin="0" />
                                        <ComboBox MinHeight="38" ItemsSource="{Binding AvailablePriorities}" SelectedItem="{Binding SelectedPriority}" IsEnabled="{Binding CanEditTicket}" />
                                    </StackPanel>
                                </Grid>

                                <UniformGrid Columns="2" Rows="2" Margin="0,4,0,0">
                                    <Button Classes="btn-primary" Content="Zapisz zmiany" Command="{Binding UpdateTicketCommand}" IsEnabled="{Binding CanEditTicket}" Margin="0,0,6,6" HorizontalAlignment="Stretch" />
                                    <Button Classes="btn-secondary" Content="Przypisz do mnie" Command="{Binding AssignToMeCommand}" IsEnabled="{Binding CanAssignTicket}" Margin="6,0,0,6" HorizontalAlignment="Stretch" />
                                    <Button Classes="btn-warning" Content="Zamknij zg┼éoszenie" Command="{Binding CloseTicketCommand}" IsEnabled="{Binding CanCloseTicket}" Margin="0,0,6,0" HorizontalAlignment="Stretch" />
                                    <Button Classes="btn-danger" Content="Usu┼ä zg┼éoszenie" Command="{Binding DeleteTicketCommand}" IsEnabled="{Binding CanDeleteTicket}" Margin="6,0,0,0" HorizontalAlignment="Stretch" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title-large" Text="Historia lokalnych zmian" />
                                <TextBlock Classes="section-subtitle" Text="Historia dzia┼éa┼ä wykonanych w tej aplikacji." />

                                <Border MaxHeight="220" Classes="app-subtle-panel" Padding="8">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding TicketAuditLogEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="message-bubble" Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Action}" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="{Binding UserLogin}" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" />
                                                                <TextBlock Text="┬Ě" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" />
                                                                <TextBlock Text="{Binding Timestamp}" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <TextBlock Classes="empty-state" Text="Brak lokalnych wpis├│w dla tego zg┼éoszenia." IsVisible="{Binding HasNoTicketAuditLogEntries}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Classes="app-card" MinHeight="480" MaxWidth="720" HorizontalAlignment="Stretch" Padding="0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="18,18,18,12" Spacing="4">
                            <TextBlock Classes="section-title-large" Text="Wiadomości" />
                            <TextBlock Classes="section-subtitle" Text="Korespondencja w ramach zg┼éoszenia." />
                        </StackPanel>

                        <Border
                            DockPanel.Dock="Bottom"
                            BorderBrush="{DynamicResource AppCardBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="18,14">

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBox
                                    Grid.Column="0"
                                    Text="{Binding NewMessageText}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    PlaceholderText="Wpisz wiadomość..."
                                    IsEnabled="{Binding CanSendMessage}" />

                                <Button
                                    Grid.Column="1"
                                    Classes="btn-primary"
                                    Content="Wy┼Ťlij"
                                    Command="{Binding SendMessageCommand}"
                                    IsEnabled="{Binding CanSendMessage}"
                                    VerticalAlignment="Bottom"
                                    MinWidth="100" />
                            </Grid>
                        </Border>

                        <Panel Margin="18,0,18,12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="message-bubble" Margin="0,0,0,10">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="{Binding Sender.Name}" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CreatedAt}" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock
                                Classes="empty-state"
                                Text="Brak wiadomo┼Ťci w tym zg┼éoszeniu."
                                IsVisible="{Binding HasNoMessages}" />
                        </Panel>
                    </DockPanel>
                </Border>
            </Grid>
</UserControl>