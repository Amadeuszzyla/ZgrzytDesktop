<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.TicketDetailsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:ZgrzytDesktop.Converters"
    xmlns:parts="clr-namespace:ZgrzytDesktop.Views.DashboardParts"
    xmlns:vm="using:ZgrzytDesktop.ViewModels"
    x:CompileBindings="False"
    x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:ObjectIsNotNullConverter x:Key="ObjectIsNotNullConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Classes="page-content">
            <Button
                Classes="details-back-link"
                Content="{Binding LblDetailsBackToList}"
                Command="{Binding ShowTicketsPageCommand}"
                HorizontalAlignment="Left"
                Margin="0,0,0,4" />

            <Border Classes="app-card details-main-card">
                <DockPanel LastChildFill="True">
                    <Border
                        DockPanel.Dock="Right"
                        Classes="details-actions-panel"
                        Width="280"
                        Margin="24,0,0,0"
                        IsVisible="{Binding CanManageTickets}">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section-title" Text="{Binding LblDetailsManageTitle}" />

                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="{Binding LblGridStatus}" Margin="0" />
                                <ComboBox
                                    MinHeight="38"
                                    ItemsSource="{Binding AvailableStatuses}"
                                    SelectedItem="{Binding TicketDetailsPanel.SelectedStatus}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanEditTicket}"
                                    HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="field-label" Text="{Binding LblGridPriority}" Margin="0" />
                                <ComboBox
                                    MinHeight="38"
                                    ItemsSource="{Binding AvailablePriorities}"
                                    SelectedItem="{Binding TicketDetailsPanel.SelectedPriority}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanEditTicket}"
                                    HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Spacing="8" Margin="0,4,0,0">
                                <Button
                                    Classes="btn-primary"
                                    Content="{Binding LblDetailsSaveChanges}"
                                    Command="{Binding TicketDetailsPanel.UpdateTicketCommand}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanEditTicket}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="40" />
                                <Button
                                    Classes="btn-secondary"
                                    Content="{Binding LblDetailsAssignToMe}"
                                    Command="{Binding TicketDetailsPanel.AssignToMeCommand}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanAssignTicket}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="40" />
                                <Button
                                    Classes="btn-warning"
                                    Content="{Binding LblDetailsCloseTicket}"
                                    Command="{Binding TicketDetailsPanel.CloseTicketCommand}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanCloseTicket}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="40" />
                                <Button
                                    Classes="btn-danger"
                                    Content="{Binding LblDetailsDeleteTicket}"
                                    Command="{Binding TicketDetailsPanel.DeleteTicketCommand}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanDeleteTicket}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="40" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="14">
                        <TextBlock Classes="section-title-large" Text="{Binding LblDetailsInfoTitle}" />

                        <TextBlock
                            Text="{Binding LblDetailsProcessing}"
                            IsVisible="{Binding TicketDetailsPanel.IsLoadingDetails}"
                            FontStyle="Italic"
                            Foreground="{DynamicResource AppMutedTextBrush}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock
                                Grid.Column="0"
                                Classes="ticket-title"
                                Text="{Binding TicketDetailsPanel.TicketDetails.Title}"
                                VerticalAlignment="Center" />
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Top">
                                <parts:TicketPriorityBadgeView Priority="{Binding TicketDetailsPanel.TicketDetails.DisplayPriority}" />
                                <parts:TicketStatusBadgeView DisplayStatus="{Binding TicketDetailsPanel.TicketDetails.DisplayStatus}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Classes="field-label"
                                Text="{Binding LblDetailsReporter}"
                                Margin="0" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding TicketDetailsPanel.TicketDetails.User.Name}"
                                Foreground="{DynamicResource AppPrimaryTextBrush}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Classes="field-label"
                                Text="{Binding LblDetailsAssignedIt}"
                                Margin="0" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding TicketDetailsPanel.TicketDetails.AssignedTo.Name}"
                                Foreground="{DynamicResource AppPrimaryTextBrush}"
                                IsVisible="{Binding TicketDetailsPanel.TicketDetails.AssignedTo, Converter={StaticResource ObjectIsNotNullConverter}}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Foreground="{DynamicResource AppMutedTextBrush}"
                                FontStyle="Italic"
                                Text="—"
                                IsVisible="{Binding TicketDetailsPanel.TicketDetails.AssignedTo, Converter={StaticResource ObjectIsNotNullConverter}, ConverterParameter=invert}" />
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Classes="field-label" Text="{Binding LblDetailsDescription}" Margin="0" />
                            <Border Classes="app-subtle-panel">
                                <TextBlock
                                    Text="{Binding TicketDetailsPanel.TicketDetails.Description}"
                                    TextWrapping="Wrap"
                                    Foreground="{DynamicResource AppSecondaryTextBrush}" />
                            </Border>
                        </StackPanel>

                        <Border
                            Background="{DynamicResource AppInfoPanelBackgroundBrush}"
                            CornerRadius="10"
                            Padding="12"
                            IsVisible="{Binding IsRegularUser}">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    Text="{Binding LblDetailsCloseOwnHint}"
                                    TextWrapping="Wrap"
                                    Foreground="{DynamicResource AppInfoPanelForegroundBrush}"
                                    FontSize="12"
                                    IsVisible="{Binding TicketDetailsPanel.CanCloseOwnTicket}" />
                                <TextBlock
                                    Text="{Binding LblDetailsStaffHint}"
                                    TextWrapping="Wrap"
                                    Foreground="{DynamicResource AppInfoPanelForegroundBrush}"
                                    FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border
                            Background="{DynamicResource AppWarnPanelBackgroundBrush}"
                            CornerRadius="10"
                            Padding="12"
                            IsVisible="{Binding IsOffline}">
                            <TextBlock
                                Text="{Binding LblDetailsOfflineHint}"
                                TextWrapping="Wrap"
                                Foreground="{DynamicResource AppWarnPanelForegroundBrush}" />
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Classes="app-card details-messages-card" Padding="0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="18,18,18,12" Spacing="4">
                        <TextBlock Classes="section-title-large" Text="{Binding LblDetailsMessagesTitle}" />
                        <TextBlock Classes="section-subtitle" Text="{Binding LblDetailsMessagesSubtitle}" />
                    </StackPanel>

                    <Border
                        DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource AppCardBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="18,14">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Text="{Binding TicketDetailsPanel.DetailsStatusMessage}"
                                TextWrapping="Wrap"
                                Foreground="{DynamicResource AppSecondaryTextBrush}"
                                FontSize="12" />

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBox
                                    Grid.Column="0"
                                    Text="{Binding TicketDetailsPanel.NewMessageText}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    MaxWidth="720"
                                    HorizontalAlignment="Stretch"
                                    PlaceholderText="{Binding LblDetailsMessagePlaceholder}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanSendMessage}" />
                                <Button
                                    Grid.Column="1"
                                    Classes="btn-primary"
                                    Content="{Binding LblDetailsSend}"
                                    Command="{Binding TicketDetailsPanel.SendMessageCommand}"
                                    IsEnabled="{Binding TicketDetailsPanel.CanSendMessage}"
                                    VerticalAlignment="Bottom"
                                    MinWidth="100"
                                    MinHeight="40" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Panel Margin="18,0,18,12" MinHeight="220">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Classes="details-messages-list" MaxWidth="720" HorizontalAlignment="Left">
                                <ItemsControl ItemsSource="{Binding TicketDetailsPanel.Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="message-bubble">
                                                <StackPanel Spacing="6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock
                                                            Text="{Binding Sender.Name}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Text="{Binding CreatedAt}"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource AppMutedTextBrush}" />
                                                    </Grid>
                                                    <TextBlock
                                                        Text="{Binding Content}"
                                                        TextWrapping="Wrap"
                                                        Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock
                            Classes="empty-state"
                            Text="{Binding LblDetailsNoMessages}"
                            IsVisible="{Binding TicketDetailsPanel.HasNoMessages}"
                            IsHitTestVisible="False" />
                    </Panel>
                </DockPanel>
            </Border>

            <Border Classes="app-card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title-large" Text="{Binding LblDetailsLocalAuditTitle}" />
                    <TextBlock Classes="section-subtitle" Text="{Binding LblDetailsLocalAuditSubtitle}" />

                    <Border MaxHeight="220" Classes="app-subtle-panel" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TicketDetailsPanel.TicketAuditLogEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="message-bubble" Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    Text="{Binding DisplayAction}"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                                <TextBlock
                                                    Text="{Binding DisplayDescription}"
                                                    TextWrapping="Wrap"
                                                    Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock
                                                        Text="{Binding DisplayUserLogin}"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource AppMutedTextBrush}" />
                                                    <TextBlock
                                                        Text="·"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource AppMutedTextBrush}" />
                                                    <TextBlock
                                                        Text="{Binding Timestamp}"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource AppMutedTextBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock
                        Classes="empty-state"
                        Text="{Binding LblDetailsLocalAuditEmpty}"
                        IsVisible="{Binding TicketDetailsPanel.HasNoTicketAuditLogEntries}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
