<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.StatisticsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Classes="page-content">
                    <Border Classes="app-card">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section-title-large" Text="{Binding StatisticsPanel.LblStatsTitle}" />
                            <TextBlock Classes="section-subtitle" Text="{Binding StatisticsPanel.StatsScopeMessage}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="btn-secondary" Content="{Binding StatisticsPanel.LblStatsLoadAll}" Command="{Binding StatisticsPanel.LoadAllPagesStatisticsCommand}" IsEnabled="{Binding StatisticsPanel.IsNotLoading}" />
                            </StackPanel>
                            <TextBlock Text="Trwa agregacja wielu stron listy..." Foreground="{DynamicResource AppMutedTextBrush}" IsVisible="{Binding StatisticsPanel.IsLoadingAllStatistics}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="app-card">
                        <UniformGrid Columns="5" Rows="1">
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding StatisticsPanel.LblStatsKpiAll}" Foreground="{DynamicResource AppSecondaryTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatisticsPanel.StatsTotalTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding StatisticsPanel.LblStatsKpiNew}" Foreground="{DynamicResource AppChipForegroundBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatisticsPanel.StatsNewTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding StatisticsPanel.LblStatsKpiInProgress}" Foreground="{DynamicResource AppChipWarningForegroundBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatisticsPanel.StatsInProgressTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding StatisticsPanel.LblStatsKpiClosed}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatisticsPanel.StatsClosedTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card" Margin="0">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding StatisticsPanel.LblStatsKpiHighPriority}" Foreground="{DynamicResource AppDangerBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatisticsPanel.StatsHighPriorityTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Według statusu" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Nowe" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsNewTickets}" Foreground="{DynamicResource AppSuccessBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsNewTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="W toku" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsInProgressTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsInProgressTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Rozwiązane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsClosedTickets}" Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsClosedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Według priorytetu" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Niski" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsLowPriorityTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsLowPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Średni" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsMediumPriorityTickets}" Foreground="{DynamicResource AppChipWarningForegroundBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsMediumPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Wysoki" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsHighPriorityTickets}" Foreground="{DynamicResource AppDangerBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsHighPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Przypisanie" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Przypisane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsAssignmentChartMaximum}" Value="{Binding StatisticsPanel.StatsAssignedTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsAssignedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Nieprzypisane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatisticsPanel.StatsAssignmentChartMaximum}" Value="{Binding StatisticsPanel.StatsUnassignedTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatisticsPanel.StatsUnassignedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
</UserControl>
