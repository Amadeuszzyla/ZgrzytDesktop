<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.StatisticsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Classes="page-content">
                    <Border Classes="app-card">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="section-title-large" Text="{Binding LblStatsTitle}" />
                            <TextBlock Classes="section-subtitle" Text="{Binding StatsScopeMessage}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="btn-secondary" Content="{Binding LblStatsLoadAll}" Command="{Binding LoadAllPagesStatisticsCommand}" IsEnabled="{Binding IsNotLoading}" />
                            </StackPanel>
                            <TextBlock Text="Trwa agregacja wielu stron listy..." Foreground="{DynamicResource AppMutedTextBrush}" IsVisible="{Binding IsLoadingAllStatistics}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="app-card">
                        <UniformGrid Columns="5" Rows="1">
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LblStatsKpiAll}" Foreground="{DynamicResource AppSecondaryTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatsTotalTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LblStatsKpiNew}" Foreground="{DynamicResource AppChipForegroundBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatsNewTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LblStatsKpiInProgress}" Foreground="{DynamicResource AppChipWarningForegroundBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatsInProgressTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LblStatsKpiClosed}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatsClosedTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Classes="kpi-card" Margin="0">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding LblStatsKpiHighPriority}" Foreground="{DynamicResource AppDangerBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding StatsHighPriorityTickets}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryTextBrush}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <Border Grid.Column="0" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Wed┼éug statusu" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Nowe" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsStatusChartMaximum}" Value="{Binding StatsNewTickets}" Foreground="{DynamicResource AppSuccessBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsNewTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="W toku" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsStatusChartMaximum}" Value="{Binding StatsInProgressTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsInProgressTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Rozwi─ůzane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsStatusChartMaximum}" Value="{Binding StatsClosedTickets}" Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsClosedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Wed┼éug priorytetu" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Niski" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsPriorityChartMaximum}" Value="{Binding StatsLowPriorityTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsLowPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="┼Üredni" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsPriorityChartMaximum}" Value="{Binding StatsMediumPriorityTickets}" Foreground="{DynamicResource AppChipWarningForegroundBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsMediumPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Wysoki" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsPriorityChartMaximum}" Value="{Binding StatsHighPriorityTickets}" Foreground="{DynamicResource AppDangerBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsHighPriorityTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Classes="app-card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="section-title" Text="Przypisanie" />
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Przypisane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsAssignmentChartMaximum}" Value="{Binding StatsAssignedTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsAssignedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,48" ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="Nieprzypisane" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Height="16" Minimum="0" Maximum="{Binding StatsAssignmentChartMaximum}" Value="{Binding StatsUnassignedTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatsUnassignedTickets}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
</UserControl>