<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.StatisticsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Classes="page-content">
            <Border Classes="app-card stats-header-card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-title-large" Text="{Binding StatisticsPanel.LblStatsTitle}" />
                    <TextBlock Classes="section-subtitle" Text="{Binding StatisticsPanel.StatsScopeMessage}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Classes="btn-secondary"
                            Content="{Binding StatisticsPanel.LblStatsLoadAll}"
                            Command="{Binding StatisticsPanel.LoadAllPagesStatisticsCommand}"
                            IsEnabled="{Binding StatisticsPanel.IsNotLoading}"
                            MinHeight="38" />
                    </StackPanel>
                    <TextBlock
                        Text="{Binding StatisticsPanel.LblStatsLoadingAllPages}"
                        Foreground="{DynamicResource AppMutedTextBrush}"
                        IsVisible="{Binding StatisticsPanel.IsLoadingAllStatistics}" />
                </StackPanel>
            </Border>

            <WrapPanel Classes="stats-kpi-wrap">
                <Border Classes="kpi-card kpi-card-accent-purple" Width="190" MinWidth="160">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kpi-label" Text="{Binding StatisticsPanel.LblStatsKpiAll}" />
                        <TextBlock Classes="kpi-value" Text="{Binding StatisticsPanel.StatsTotalTickets}" />
                    </StackPanel>
                </Border>
                <Border Classes="kpi-card kpi-card-accent-violet" Width="190" MinWidth="160">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kpi-label" Text="{Binding StatisticsPanel.LblStatsKpiNew}" />
                        <TextBlock Classes="kpi-value" Text="{Binding StatisticsPanel.StatsNewTickets}" />
                    </StackPanel>
                </Border>
                <Border Classes="kpi-card kpi-card-accent-amber" Width="190" MinWidth="160">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kpi-label" Text="{Binding StatisticsPanel.LblStatsKpiInProgress}" />
                        <TextBlock Classes="kpi-value" Text="{Binding StatisticsPanel.StatsInProgressTickets}" />
                    </StackPanel>
                </Border>
                <Border Classes="kpi-card kpi-card-accent-green" Width="190" MinWidth="160">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kpi-label" Text="{Binding StatisticsPanel.LblStatsKpiClosed}" />
                        <TextBlock Classes="kpi-value" Text="{Binding StatisticsPanel.StatsClosedTickets}" />
                    </StackPanel>
                </Border>
                <Border Classes="kpi-card kpi-card-accent-red" Width="190" MinWidth="160">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kpi-label" Text="{Binding StatisticsPanel.LblStatsKpiHighPriority}" />
                        <TextBlock Classes="kpi-value" Text="{Binding StatisticsPanel.StatsHighPriorityTickets}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <WrapPanel Classes="stats-charts-wrap">
                <Border Classes="app-card stats-chart-card" MinWidth="280" Width="360">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="{Binding StatisticsPanel.LblStatsChartByStatus}" />
                        <StackPanel Spacing="10" Classes="stats-progress-group">
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsKpiNew}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsNewTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsNewTickets}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsKpiInProgress}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsInProgressTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsInProgressTickets}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsKpiClosed}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsStatusChartMaximum}" Value="{Binding StatisticsPanel.StatsClosedTickets}" Foreground="{DynamicResource AppSuccessBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsClosedTickets}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="app-card stats-chart-card" MinWidth="280" Width="360">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="{Binding StatisticsPanel.LblStatsChartByPriority}" />
                        <StackPanel Spacing="10" Classes="stats-progress-group">
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsPriorityLow}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsLowPriorityTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsLowPriorityTickets}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsPriorityMedium}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsMediumPriorityTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsMediumPriorityTickets}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsPriorityHigh}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsPriorityChartMaximum}" Value="{Binding StatisticsPanel.StatsHighPriorityTickets}" Foreground="{DynamicResource AppDangerBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsHighPriorityTickets}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="app-card stats-chart-card" MinWidth="280" Width="360">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="section-title" Text="{Binding StatisticsPanel.LblStatsChartAssignment}" />
                        <StackPanel Spacing="10" Classes="stats-progress-group">
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsAssigned}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsAssignmentChartMaximum}" Value="{Binding StatisticsPanel.StatsAssignedTickets}" Foreground="{DynamicResource AppAccentBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsAssignedTickets}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*,36" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Classes="stats-progress-label" Text="{Binding StatisticsPanel.LblStatsUnassigned}" TextWrapping="Wrap" />
                                <ProgressBar Grid.Column="1" Classes="stats-progress" Minimum="0" Maximum="{Binding StatisticsPanel.StatsAssignmentChartMaximum}" Value="{Binding StatisticsPanel.StatsUnassignedTickets}" Foreground="{DynamicResource AppWarningBrush}" />
                                <TextBlock Grid.Column="2" Classes="stats-progress-value" Text="{Binding StatisticsPanel.StatsUnassignedTickets}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Classes="app-card stats-response-time-card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title" Text="{Binding StatisticsPanel.LblStatsResponseTime}" />
                    <TextBlock
                        Classes="section-subtitle"
                        Text="{Binding StatisticsPanel.StatsResponseTimeMessage}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
