<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.AdminPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:ZgrzytDesktop.Converters"
    xmlns:parts="clr-namespace:ZgrzytDesktop.Views.DashboardParts"
    xmlns:vm="using:ZgrzytDesktop.ViewModels"
    x:CompileBindings="False"
    x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
        <conv:UserCanActivateConverter x:Key="UserCanActivateConverter" />
        <conv:UserCanUnbanConverter x:Key="UserCanUnbanConverter" />
        <conv:AdminUserMetaConverter x:Key="AdminUserMetaConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Classes="page-content">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                <Button
                    Classes="btn-secondary"
                    Classes.active="{Binding IsAdminUsersTabActive}"
                    Content="{Binding LblAdminTabUsers}"
                    Command="{Binding ShowAdminUsersTabCommand}"
                    IsVisible="{Binding IsAdminRole}"
                    MinWidth="120" />
                <Button
                    Classes="btn-secondary"
                    Classes.active="{Binding IsAdminNewAccountTabActive}"
                    Content="{Binding LblAdminTabNewAccount}"
                    Command="{Binding ShowAdminNewAccountTabCommand}"
                    IsVisible="{Binding IsStaffRole}"
                    MinWidth="120" />
            </StackPanel>

            <StackPanel Spacing="16" IsVisible="{Binding IsAdminUsersPanelVisible}">
                <StackPanel Spacing="4">
                    <TextBlock Classes="section-title-large" Text="{Binding LblAdminUsersTitle}" />
                    <TextBlock Classes="section-subtitle" Text="{Binding LblAdminUsersSubtitle}" />
                </StackPanel>

                <Border Classes="app-card admin-toolbar-card">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <ComboBox
                                Grid.Column="0"
                                MinWidth="180"
                                MinHeight="38"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding AdminUserListFilterOptions}"
                                SelectedItem="{Binding SelectedAdminUserListFilterOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                                <TextBox
                                    MinWidth="180"
                                    MinHeight="38"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding ShowAdminUnbanPassword}"
                                    Text="{Binding AdminUnbanPassword}"
                                    PasswordChar="•"
                                    PlaceholderText="{Binding LblAdminUnbanPassword}" />
                                <Button
                                    Classes="btn-secondary"
                                    Content="{Binding LblAdminRefreshList}"
                                    Command="{Binding LoadAdminUsersCommand}"
                                    MinWidth="130"
                                    MinHeight="38"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Text="{Binding AdminStatusMessage}"
                            TextWrapping="Wrap"
                            Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    </StackPanel>
                </Border>

                <Panel MinHeight="200">
                    <ListBox
                        Classes="admin-user-list"
                        ItemsSource="{Binding AdminUsers}"
                        SelectedItem="{Binding SelectedAdminUser}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="admin-user-card" Padding="16,14">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
                                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock
                                                Classes="admin-user-name"
                                                Text="{Binding Name}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Classes="admin-user-meta"
                                                Text="{Binding Login, Converter={StaticResource AdminUserMetaConverter}, ConverterParameter=login}" />
                                            <TextBlock
                                                Classes="admin-user-meta"
                                                Text="{Binding Email, Converter={StaticResource AdminUserMetaConverter}, ConverterParameter=email}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Classes="admin-user-meta"
                                                Text="{Binding Role, Converter={StaticResource AdminUserMetaConverter}, ConverterParameter=role}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                            <parts:UserActiveBadgeView IsActive="{Binding Active}" />
                                            <parts:UserBanBadgeView IsBanned="{Binding Ban}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Spacing="6"
                                            VerticalAlignment="Center"
                                            MinWidth="120">
                                            <Button
                                                Classes="btn-primary"
                                                Content="{Binding DataContext.LblAdminActivate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Click="OnActivateUserClick"
                                                IsEnabled="{Binding Converter={StaticResource UserCanActivateConverter}}"
                                                MinHeight="34"
                                                HorizontalAlignment="Stretch" />
                                            <Button
                                                Classes="btn-danger"
                                                Content="{Binding DataContext.LblAdminBan, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Click="OnBanUserClick"
                                                IsEnabled="{Binding Ban, Converter={StaticResource InvertBoolConverter}}"
                                                MinHeight="34"
                                                HorizontalAlignment="Stretch" />
                                            <Button
                                                Classes="btn-secondary"
                                                Content="{Binding DataContext.LblAdminUnban, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Click="OnUnbanUserClick"
                                                IsEnabled="{Binding Converter={StaticResource UserCanUnbanConverter}}"
                                                MinHeight="34"
                                                HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock
                        Classes="tickets-empty-state"
                        Text="{Binding LblAdminNoUsersFound}"
                        IsVisible="{Binding HasNoAdminUsers}"
                        IsHitTestVisible="False" />
                </Panel>
            </StackPanel>

            <Panel IsVisible="{Binding IsAdminNewAccountPanelVisible}" Margin="0,8,0,0">
                <Border
                    Classes="account-form-card"
                    MaxWidth="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                    <StackPanel Spacing="22">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock
                                Classes="account-form-title"
                                Text="{Binding LblRegisterUserTitle}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center" />
                            <TextBlock
                                Classes="account-form-subtitle"
                                Text="{Binding LblRegisterUserSubtitle}"
                                HorizontalAlignment="Center"
                                TextAlignment="Center" />
                        </StackPanel>

                        <parts:RegisterUserFormView />
                    </StackPanel>
                </Border>
            </Panel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
