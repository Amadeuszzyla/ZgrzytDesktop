<UserControl
    x:Class="ZgrzytDesktop.Views.DashboardParts.SettingsPanelView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False">
<ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Classes="page-content" Spacing="20">
                    <Border Classes="app-card">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title-large" Text="{Binding SettingsPanel.LblSettingsTitle}" />
                            <TextBlock Classes="section-subtitle" Text="{Binding SettingsPanel.LblSettingsSubtitle}" />

                            <TextBlock Classes="field-label" Text="{Binding SettingsPanel.LblSettingsTheme}" Margin="0" />
                            <ComboBox
                                ItemsSource="{Binding SettingsPanel.ThemeModes}"
                                SelectedItem="{Binding SettingsPanel.SelectedThemeMode}"
                                MinHeight="38"
                                HorizontalAlignment="Stretch" />

                            <TextBlock Classes="field-label" Text="{Binding SettingsPanel.LblSettingsLanguage}" Margin="0,8,0,0" />
                            <ComboBox
                                ItemsSource="{Binding SettingsPanel.UiCultures}"
                                SelectedItem="{Binding SettingsPanel.SelectedUiCulture}"
                                MinHeight="38"
                                HorizontalAlignment="Stretch" />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    Classes="btn-primary"
                                    Content="{Binding SettingsPanel.LblSettingsSave}"
                                    Command="{Binding SettingsPanel.SaveSettingsCommand}"
                                    MinWidth="160"
                                    MinHeight="36" />
                                <Button
                                    Classes="btn-secondary"
                                    Content="{Binding SettingsPanel.LblSettingsRefreshSession}"
                                    Command="{Binding SettingsPanel.RefreshSessionCommand}"
                                    MinWidth="180"
                                    MinHeight="36" />
                            </StackPanel>

                            <TextBlock Text="{Binding SettingsPanel.SettingsStatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="app-card">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="section-title-large" Text="Lokalny audyt aplikacji" />
                            <TextBlock
                                Classes="section-subtitle"
                                Text="Lista akcji wykonanych lokalnie w aplikacji desktopowej." />

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    Classes="btn-secondary"
                                    Content="Odśwież audyt"
                                    Command="{Binding AuditPanel.LoadAuditLogsCommand}"
                                    MinWidth="130"
                                    MinHeight="36" />
                                <Button
                                    Classes="btn-secondary"
                                    Content="Wyczyść audyt"
                                    Command="{Binding AuditPanel.ClearAuditLogsCommand}"
                                    MinWidth="130"
                                    MinHeight="36" />
                            </StackPanel>

                            <DataGrid
                                ItemsSource="{Binding AuditPanel.AuditLogEntries}"
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                CanUserSortColumns="False"
                                MinHeight="200"
                                MaxHeight="420"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Data i czas" Binding="{Binding Timestamp}" Width="180" />
                                    <DataGridTextColumn Header="Użytkownik" Binding="{Binding UserLogin}" Width="160" />
                                    <DataGridTextColumn Header="Akcja" Binding="{Binding Action}" Width="200" />
                                    <DataGridTextColumn Header="ID zgłoszenia" Binding="{Binding TicketId}" Width="100" />
                                    <DataGridTemplateColumn Header="Opis" Width="*" MinWidth="350">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Text="{Binding Description}"
                                                    TextWrapping="Wrap"
                                                    MaxHeight="72"
                                                    ToolTip.Tip="{Binding Description}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock
                                Classes="empty-state"
                                Text="Brak lokalnych wpisów audytu."
                                IsVisible="{Binding AuditPanel.HasNoAuditLogEntries}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
</UserControl>
