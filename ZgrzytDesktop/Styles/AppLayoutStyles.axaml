<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.app-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="{DynamicResource AppCardPadding}" />
        <Setter Property="Margin" Value="{DynamicResource AppCardMargin}" />
    </Style>

    <Style Selector="Border.app-card-compact">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="Border.app-toolbar">
        <Setter Property="Background" Value="{DynamicResource AppToolbarBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="Border.app-subtle-panel">
        <Setter Property="Background" Value="{DynamicResource AppSubtlePanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="Border.app-chip">
        <Setter Property="Background" Value="{DynamicResource AppChipBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="Border.app-chip-warning">
        <Setter Property="Background" Value="{DynamicResource AppChipWarningBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="TextBlock.app-chip-text">
        <Setter Property="Foreground" Value="{DynamicResource AppChipForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.app-chip-text-warning">
        <Setter Property="Foreground" Value="{DynamicResource AppChipWarningForegroundBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.section-title-large">
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.section-subtitle">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style Selector="TextBlock.field-label">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style Selector="TextBlock.ticket-title">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.empty-state">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AppEmptyStateForegroundBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="16" />
    </Style>

    <Style Selector="StackPanel.page-content">
        <Setter Property="Spacing" Value="20" />
        <Setter Property="Margin" Value="{DynamicResource AppPagePadding}" />
        <Setter Property="MaxWidth" Value="{DynamicResource AppContentMaxWidth}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="StackPanel.stats-page-content">
        <Setter Property="Spacing" Value="24" />
    </Style>

    <Style Selector="Border.kpi-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="MinHeight" Value="108" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="BoxShadow" Value="0 3 12 0 #0000000D" />
    </Style>

    <Style Selector="TextBlock.kpi-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.kpi-value">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="LineHeight" Value="40" />
    </Style>

    <Style Selector="Border.kpi-card-accent-purple">
        <Setter Property="Background" Value="#F5F3FF" />
        <Setter Property="BorderBrush" Value="#7C3AED" />
        <Setter Property="BorderThickness" Value="1,1,1,4" />
    </Style>

    <Style Selector="Border.kpi-card-accent-violet">
        <Setter Property="Background" Value="#F3E8FF" />
        <Setter Property="BorderBrush" Value="#8B5CF6" />
        <Setter Property="BorderThickness" Value="1,1,1,4" />
    </Style>

    <Style Selector="Border.kpi-card-accent-amber">
        <Setter Property="Background" Value="#FFFBEB" />
        <Setter Property="BorderBrush" Value="#D97706" />
        <Setter Property="BorderThickness" Value="1,1,1,4" />
    </Style>

    <Style Selector="Border.kpi-card-accent-green">
        <Setter Property="Background" Value="#ECFDF5" />
        <Setter Property="BorderBrush" Value="#059669" />
        <Setter Property="BorderThickness" Value="1,1,1,4" />
    </Style>

    <Style Selector="Border.kpi-card-accent-red">
        <Setter Property="Background" Value="#FEF2F2" />
        <Setter Property="BorderBrush" Value="#DC2626" />
        <Setter Property="BorderThickness" Value="1,1,1,4" />
    </Style>

    <Style Selector="Grid.stats-kpi-grid">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Grid.stats-charts-grid">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Border.stats-chart-card">
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="MinHeight" Value="220" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.stats-header-card">
        <Setter Property="Padding" Value="22,20" />
    </Style>

    <Style Selector="Button.stats-load-all-button">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="MinWidth" Value="220" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <Style Selector="TextBlock.stats-loading-hint">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <Style Selector="TextBlock.stats-chart-title">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="TextBlock.stats-progress-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.stats-progress-value">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style Selector="ProgressBar.stats-progress">
        <Setter Property="Height" Value="14" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Background" Value="#E5E7EB" />
    </Style>

    <Style Selector="StackPanel.stats-progress-group">
        <Setter Property="Spacing" Value="14" />
    </Style>

    <!-- Sidebar navigation -->
    <Style Selector="Button.sidebar-nav">
        <Setter Property="Background" Value="{DynamicResource SidebarNavBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarNavForegroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,3" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="Button.sidebar-nav:pointerover">
        <Setter Property="Background" Value="{DynamicResource SidebarNavPointerOverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarPrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.sidebar-nav:pressed">
        <Setter Property="Background" Value="{DynamicResource SidebarNavPressedBrush}" />
    </Style>

    <Style Selector="Button.sidebar-nav:disabled">
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Background" Value="{DynamicResource SidebarNavBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarMutedTextBrush}" />
    </Style>

    <Style Selector="Button.sidebar-nav.active">
        <Setter Property="Background" Value="{DynamicResource SidebarNavActiveBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarNavActiveForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarNavActiveAccentBrush}" />
        <Setter Property="BorderThickness" Value="3,1,1,1" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.sidebar-nav.active:pointerover">
        <Setter Property="Background" Value="{DynamicResource SidebarNavActiveBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarNavActiveForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarNavActiveAccentBrush}" />
        <Setter Property="BorderThickness" Value="3,1,1,1" />
    </Style>

    <Style Selector="Button.sidebar-logout">
        <Setter Property="Background" Value="{DynamicResource SidebarLogoutBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarNavForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style Selector="Button.sidebar-logout:pointerover">
        <Setter Property="Background" Value="{DynamicResource SidebarLogoutPointerOverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarPrimaryTextBrush}" />
    </Style>

    <Style Selector="Button.sidebar-logout:pressed">
        <Setter Property="Background" Value="{DynamicResource SidebarNavPressedBrush}" />
    </Style>

    <!-- Action buttons -->
    <Style Selector="Button.btn-primary">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-primary:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppAccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
    </Style>

    <Style Selector="Button.btn-secondary">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryButtonBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppSecondaryButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryButtonHoverBrush}" />
    </Style>

    <Style Selector="Button.btn-secondary:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundDisabledBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderDisabledBrush}" />
    </Style>

    <Style Selector="Button.btn-primary:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundDisabledBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderDisabledBrush}" />
    </Style>

    <Style Selector="Button.btn-danger:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundDisabledBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundDisabledBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderDisabledBrush}" />
    </Style>

    <Style Selector="Button.btn-secondary.active">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.btn-warning">
        <Setter Property="Background" Value="{DynamicResource AppWarningBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppWarningForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-danger">
        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppDangerForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-danger:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppDangerHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerHoverBrush}" />
    </Style>

    <Style Selector="Button.btn-ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="Button.btn-ghost:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryButtonHoverBrush}" />
    </Style>

    <Style Selector="Button.filter-action">
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.message-bubble">
        <Setter Property="Background" Value="{DynamicResource AppMessageBubbleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- Topbar -->
    <Style Selector="Border.app-topbar">
        <Setter Property="Background" Value="{DynamicResource AppTopBarBackgroundBrush}" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="BorderBrush" Value="#1F2937" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style Selector="Image.topbar-logo">
        <Setter Property="Stretch" Value="Uniform" />
    </Style>

    <Style Selector="TextBlock.topbar-brand">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTopBarForegroundBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="LetterSpacing" Value="1" />
    </Style>

    <Style Selector="Button.topbar-nav">
        <Setter Property="Background" Value="{DynamicResource AppTopBarNavBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTopBarNavForegroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.topbar-nav:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppTopBarNavPointerOverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTopBarForegroundBrush}" />
    </Style>

    <Style Selector="Button.topbar-nav.active">
        <Setter Property="Background" Value="{DynamicResource AppTopBarNavActiveBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTopBarNavActiveForegroundBrush}" />
    </Style>

    <Style Selector="Button.topbar-nav.active:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppTopBarNavActiveBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTopBarNavActiveForegroundBrush}" />
    </Style>

    <!-- User / version badges -->
    <Style Selector="Border.user-badge">
        <Setter Property="Background" Value="{DynamicResource AppUserBadgeBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="BorderBrush" Value="#4338CA" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.user-badge-text">
        <Setter Property="Foreground" Value="{DynamicResource AppUserBadgeForegroundBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.version-badge">
        <Setter Property="Background" Value="{DynamicResource AppVersionBadgeBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppVersionBadgeBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.version-badge-text">
        <Setter Property="Foreground" Value="{DynamicResource AppVersionBadgeForegroundBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Pill badge (generic) -->
    <Style Selector="Border.pill-badge">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Background" Value="{DynamicResource AppChipBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppChipForegroundBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.pill-badge-text">
        <Setter Property="Foreground" Value="{DynamicResource AppChipForegroundBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Toast -->
    <Style Selector="Border.toast-card">
        <Setter Property="Background" Value="{DynamicResource AppToastCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppToastCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="BoxShadow" Value="0 8 24 0 #00000020" />
    </Style>

    <Style Selector="TextBlock.toast-text">
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Outline buttons -->
    <Style Selector="Button.btn-outline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-outline:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppChipBackgroundBrush}" />
    </Style>

    <Style Selector="Button.btn-outline-danger">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppOutlineDangerForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppOutlineDangerBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-outline-danger:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppOutlineDangerHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppOutlineDangerForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppOutlineDangerBorderBrush}" />
    </Style>

    <!-- Login page -->
    <Style Selector="Border.login-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="36,32" />
        <Setter Property="BoxShadow" Value="0 8 24 0 #00000014" />
    </Style>

    <Style Selector="TextBlock.login-welcome-title">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.login-welcome-subtitle">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <Style Selector="TextBlock.login-field-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style Selector="TextBox.login-field">
        <Setter Property="Background" Value="#E5E7EB" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="TextBox.login-field:focus, TextBox.login-field:focus-within">
        <Setter Property="Background" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="TextBox.login-field /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
    </Style>

    <Style Selector="TextBox.login-field:focus /template/ Border#PART_BorderElement, TextBox.login-field:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
    </Style>

    <Style Selector="Button.login-submit">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="Border.login-error">
        <Setter Property="Background" Value="#FEF2F2" />
        <Setter Property="BorderBrush" Value="#FECACA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style Selector="TextBlock.login-error-text">
        <Setter Property="Foreground" Value="#B91C1C" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Border.login-status">
        <Setter Property="Background" Value="#EFF6FF" />
        <Setter Property="BorderBrush" Value="#BFDBFE" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style Selector="TextBlock.login-status-text">
        <Setter Property="Foreground" Value="#1D4ED8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button.login-auto-cancel">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!-- Tickets panel — card list -->
    <Style Selector="Border.tickets-toolbar-card">
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Button.tickets-search-icon">
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="18" />
    </Style>

    <Style Selector="ListBox.ticket-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.ticket-list > ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ListBox.ticket-list > ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.ticket-list > ListBoxItem:pointerover">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Border.ticket-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="ListBox.ticket-list > ListBoxItem:selected Border.ticket-card">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="ListBox.ticket-list > ListBoxItem:pointerover Border.ticket-card">
        <Setter Property="BorderBrush" Value="#C4B5FD" />
    </Style>

    <Style Selector="TextBlock.ticket-card-title">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.ticket-card-description">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style Selector="TextBlock.ticket-card-meta">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.ticket-card-meta-muted">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <Style Selector="TextBlock.ticket-card-author">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <Style Selector="TextBlock.ticket-card-date">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <Style Selector="Border.ticket-badge">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style Selector="TextBlock.ticket-badge-text">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.ticket-badge-status-new">
        <Setter Property="Background" Value="#DBEAFE" />
    </Style>
    <Style Selector="Border.ticket-badge-status-new TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#1D4ED8" />
    </Style>

    <Style Selector="Border.ticket-badge-status-progress">
        <Setter Property="Background" Value="#FEF3C7" />
    </Style>
    <Style Selector="Border.ticket-badge-status-progress TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#B45309" />
    </Style>

    <Style Selector="Border.ticket-badge-status-closed">
        <Setter Property="Background" Value="#D1FAE5" />
    </Style>
    <Style Selector="Border.ticket-badge-status-closed TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#047857" />
    </Style>

    <Style Selector="Border.ticket-badge-status-default">
        <Setter Property="Background" Value="#F3F4F6" />
    </Style>
    <Style Selector="Border.ticket-badge-status-default TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#4B5563" />
    </Style>

    <Style Selector="Border.ticket-badge-priority-high">
        <Setter Property="Background" Value="#FEE2E2" />
    </Style>
    <Style Selector="Border.ticket-badge-priority-high TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#B91C1C" />
    </Style>

    <Style Selector="Border.ticket-badge-priority-medium">
        <Setter Property="Background" Value="#FFEDD5" />
    </Style>
    <Style Selector="Border.ticket-badge-priority-medium TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#C2410C" />
    </Style>

    <Style Selector="Border.ticket-badge-priority-low">
        <Setter Property="Background" Value="#E0E7FF" />
    </Style>
    <Style Selector="Border.ticket-badge-priority-low TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#4338CA" />
    </Style>

    <Style Selector="Border.ticket-badge-priority-default">
        <Setter Property="Background" Value="#F3F4F6" />
    </Style>
    <Style Selector="Border.ticket-badge-priority-default TextBlock.ticket-badge-text">
        <Setter Property="Foreground" Value="#4B5563" />
    </Style>

    <Style Selector="TextBlock.tickets-empty-state">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="Margin" Value="0,48" />
    </Style>

    <Style Selector="Border.tickets-pagination-card">
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Expander.tickets-create-expander">
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <!-- Ticket details -->
    <Style Selector="Button.details-back-link">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style Selector="Button.details-back-link:pointerover">
        <Setter Property="Foreground" Value="#6D28D9" />
    </Style>

    <Style Selector="Border.details-main-card">
        <Setter Property="Padding" Value="20,18" />
    </Style>

    <Style Selector="Border.details-actions-panel">
        <Setter Property="Background" Value="{DynamicResource AppSubtlePanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style Selector="Border.details-messages-card">
        <Setter Property="MinHeight" Value="360" />
    </Style>

    <Style Selector="StackPanel.details-messages-list">
        <Setter Property="Spacing" Value="0" />
    </Style>

    <!-- Admin users -->
    <Style Selector="Border.admin-toolbar-card">
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style Selector="ListBox.admin-user-list">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox.admin-user-list > ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="ListBox.admin-user-list > ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="ListBox.admin-user-list > ListBoxItem:pointerover">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Border.admin-user-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="ListBox.admin-user-list > ListBoxItem:selected Border.admin-user-card">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="ListBox.admin-user-list > ListBoxItem:pointerover Border.admin-user-card">
        <Setter Property="BorderBrush" Value="#C4B5FD" />
    </Style>

    <Style Selector="TextBlock.admin-user-name">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.admin-user-meta">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <!-- Request account / new user form -->
    <Style Selector="Border.account-form-card">
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="36,32" />
        <Setter Property="BoxShadow" Value="0 8 24 0 #00000014" />
    </Style>

    <Style Selector="TextBlock.account-form-title">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.account-form-subtitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="MaxWidth" Value="360" />
    </Style>

    <Style Selector="TextBlock.account-form-label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBox.account-form-field">
        <Setter Property="Background" Value="#E5E7EB" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.account-form-field:focus, TextBox.account-form-field:focus-within">
        <Setter Property="Background" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="TextBox.account-form-field /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#E5E7EB" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
    </Style>

    <Style Selector="TextBox.account-form-field:focus /template/ Border#PART_BorderElement, TextBox.account-form-field:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#F3F4F6" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
    </Style>

    <Style Selector="Button.account-form-submit">
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="TextBlock.account-form-status">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <!-- Settings -->
    <Style Selector="Border.settings-panel-card">
        <Setter Property="Padding" Value="20,18" />
    </Style>

    <Style Selector="WrapPanel.settings-actions-wrap">
        <Setter Property="Orientation" Value="Horizontal" />
    </Style>

    <Style Selector="ComboBox.settings-select">
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <Style Selector="ItemsControl.audit-log-list">
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Border.audit-log-row">
        <Setter Property="Background" Value="{DynamicResource AppSubtlePanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="TextBlock.audit-log-action">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
    </Style>

    <Style Selector="TextBlock.audit-log-timestamp">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="TextBlock.audit-log-description">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style Selector="TextBlock.audit-log-meta">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>

    <Style Selector="Grid.tickets-toolbar-grid">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Grid.tickets-toolbar-grid > ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Grid.tickets-toolbar-grid > TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.btn-primary:focus, Button.btn-primary:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Button.btn-secondary:focus, Button.btn-secondary:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

</Styles>
